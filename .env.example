# Copy to .env and adjust. Used by docker-compose and local processes.

POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_PORT=5432

# Backend — use localhost when running `npm run dev` on your machine.
# Use host `postgres` or `db` only inside Docker Compose (service name on that network).
DATABASE_URL=postgresql://app:app@localhost:5432/app
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_SEC=28800
CORS_ORIGIN=http://localhost:5173
PORT=3001

# Optional: OpenAI-compatible API (official OpenAI or proxies e.g. ChatAnyWhere)
OPENAI_API_KEY=
# Required for ChatAnyWhere and other OpenAI-compatible hosts (include /v1):
# OPENAI_BASE_URL=https://api.chatanywhere.tech/v1
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Optional: HKMA Open API (payments simulated if unset)
HKMA_OPENAPI_BASE_URL=
HKMA_OPENAPI_TOKEN=
HKMA_DEFAULT_CREDITOR_ACCOUNT=HK-000000000000

# Optional: tax / FX defaults for payout engine
DEFAULT_TAX_RATE=0
DEFAULT_FX_RATE=1

# Docker full stack (profile full)
API_PORT=3001
WEB_PORT=8080
CORS_ORIGIN=http://localhost:8080

# Frontend (Vite) — only needed if not using dev proxy
VITE_API_URL=
